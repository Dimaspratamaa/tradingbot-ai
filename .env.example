# ============================================================
# .ENV.EXAMPLE — Copy ke .env lalu isi nilainya
# JANGAN commit file .env ke GitHub!
# ============================================================

# ── BINANCE ───────────────────────────────────────────────
BINANCE_API_KEY=isi_api_key_binance_kamu
BINANCE_SECRET_KEY=isi_secret_key_binance_kamu
BINANCE_TESTNET=true            # true = paper trading, false = live

# ── POSTGRESQL ────────────────────────────────────────────
POSTGRES_DB=tradingbot
POSTGRES_USER=botuser
POSTGRES_PASSWORD=ganti_password_kuat_disini
DATABASE_URL=postgresql://botuser:ganti_password_kuat_disini@postgres:5432/tradingbot

# ── REDIS ─────────────────────────────────────────────────
REDIS_PASSWORD=ganti_redis_password_disini
REDIS_URL=redis://:ganti_redis_password_disini@redis:6379/0

# ── N8N ───────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=ganti_n8n_password_disini
N8N_HOST=IP_VPS_KAMU_atau_domain.com

# ── DISCORD (notifikasi) ──────────────────────────────────
DISCORD_WEBHOOK_BUY=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_ALERT=https://discord.com/api/webhooks/xxx/zzz
DISCORD_WEBHOOK_REPORT=https://discord.com/api/webhooks/xxx/www

# ── BOT SETTINGS ──────────────────────────────────────────
MODE=paper                      # paper / live
MAX_MODAL_PER_TRADE=300
MIN_MODAL_PER_TRADE=15
LOG_LEVEL=INFO
